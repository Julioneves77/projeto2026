# ============================================
# Configuração do Sync-Server
# ============================================

# Ambiente (development | production)
NODE_ENV=development

# Porta do servidor de sincronização
PORT=3001

# URL pública base para arquivos enviados (necessário para WhatsApp attachments)
# Em desenvolvimento: use ngrok ou similar para expor localhost:3001
# Em produção: use seu domínio (ex: https://api.portalcertidao.org)
PUBLIC_BASE_URL=http://localhost:3001

# ============================================
# SendPulse API (Email)
# ============================================

# Credenciais SendPulse
SENDPULSE_CLIENT_ID=seu_client_id_aqui
SENDPULSE_CLIENT_SECRET=seu_client_secret_aqui

# Email remetente (DEVE estar verificado no SendPulse)
SENDPULSE_SENDER_EMAIL=contato@portalcertidao.org
SENDPULSE_SENDER_NAME=Portal Certidão

# ============================================
# Zap API (WhatsApp)
# ============================================

# URL da API do WhatsApp (Z-API, Evolution API, etc.)
# Exemplos:
# - Z-API: https://api.z-api.io/v1
# - Evolution API: https://api.evolution-api.com/v1
ZAP_API_URL=https://api.z-api.io/v1

# API Key / Token da instância WhatsApp
# Formato pode variar conforme o provedor (instance:token ou apenas token)
ZAP_API_KEY=sua_api_key_aqui

# Client Token (se necessário para Z-API)
ZAP_CLIENT_TOKEN=seu_client_token_aqui

# ============================================
# Plexi API (Automação de Certidões)
# ============================================
# URL base da API Plexi (https://api.plexi.com.br)
PLEXI_API_URL=https://api.plexi.com.br
# Chave da API (Bearer token - obter em: Plexi > Chave da API)
PLEXI_API_KEY=sua_chave_api_plexi_aqui

# ============================================
# Segurança (Opcional - para produção)
# ============================================

# API Key para autenticação no sync-server (recomendado para produção)
# SYNC_SERVER_API_KEY=sua_api_key_secreta_aqui

# CORS Origins permitidos (separados por vírgula)
# CORS_ORIGINS=https://portalcertidao.org,https://plataforma.portalcertidao.org

# reCAPTCHA - Guia Central (guia-central.online)
# Secret Key para validar tokens do formulário Fale Conosco
# RECAPTCHA_GUIA_SECRET_KEY=sua_secret_key_recaptcha_guia_aqui
# Chave de TESTE (sempre passa) - use temporariamente se a chave real falhar
# RECAPTCHA_GUIA_TEST_SECRET=6LeIxAcTAAAAAGG-vFI1TnRWxMZNFuojJ4WifJWe

# Forçar reenvio de notificações de conclusão (ignora verificação de duplicatas nas últimas 24h)
# Use apenas para testes de reenvio de email/WhatsApp quando o envio anterior falhou
# FORCE_RESEND=true

# ============================================
# GCLID / Google Sheets (Conversões Google Ads)
# ============================================
# Chave de 32 bytes em base64 para criptografar o JSON da Service Account
# Gerar: node -e "console.log(require('crypto').randomBytes(32).toString('base64'))"
# SHEETS_CREDENTIALS_ENCRYPTION_KEY=sua_chave_base64_aqui

# Timezone para conversões (opcional)
# TZ=America/Sao_Paulo
